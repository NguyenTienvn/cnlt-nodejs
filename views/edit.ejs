<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sửa bài viết - <%= post.title %></title>
  <link rel="stylesheet" href="/css/edit.css">
</head>
<body>
  <header>
    <div class="header-content">
      <h1>Chỉnh sửa bài viết</h1>
      <a href="/post/<%= post._id %>" class="btn btn-secondary">Quay lại</a>
    </div>
  </header>

  <div class="container">
    <main>
      <form action="/post/<%= post._id %>/update" method="POST" class="post-form" enctype="multipart/form-data">
        <div class="form-group">
          <label for="title">Tiêu đề bài viết</label>
          <input type="text" id="title" name="title" value="<%= post.title %>" required autofocus>
        </div>

        <div class="form-group">
          <label for="author">Tác giả</label>
          <input type="text" id="author" name="author" value="<%= post.author %>" required>
        </div>

        <div class="form-group">
          <label for="image">Hình ảnh (tùy chọn - để trống nếu không đổi)</label>
          <% if (post.image) { %>
            <div class="current-image">
              <p>Ảnh hiện tại:</p>
              <img src="<%= post.image %>" alt="Current image">
            </div>
          <% } %>
          <input type="file" id="image" name="image" accept="image/*" onchange="previewImage(event)">
          <div id="imagePreview" class="image-preview"></div>
        </div>

        <div class="form-group">
          <label for="content">Nội dung bài viết</label>
          <textarea id="content" name="content" required><%= post.content %></textarea>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">Cập nhật</button>
          <a href="/post/<%= post._id %>" class="btn btn-secondary">Hủy</a>
        </div>
      </form>
    </main>
  </div>

  <script>
    function previewImage(event) {
      const preview = document.getElementById('imagePreview');
      const file = event.target.files[0];
      
      if (file) {
        const reader = new FileReader();
        reader.onload = function(e) {
          preview.innerHTML = '<img src="' + e.target.result + '" alt="Preview">';
        }
        reader.readAsDataURL(file);
      } else {
        preview.innerHTML = '';
      }
    }
  </script>
</body>
</html>
